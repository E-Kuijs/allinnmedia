{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_FUNCTION_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "__SET_IN_EAS_DASHBOARD__"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_FUNCTION_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "__SET_IN_EAS_DASHBOARD__"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_FUNCTION_URL": "__SET_IN_EAS_DASHBOARD__",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "__SET_IN_EAS_DASHBOARD__"
      }
    }
  },
  "submit": {
    "production": {}
  }
}